{
  "kind": "collectionType",
  "collectionName": "specializedcourses",
  "info": {
    "singularName": "specializedcourse",
    "pluralName": "specializedcourses",
    "displayName": "Specialized Course",
    "mainField": "courseName"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "courseName": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "program": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::program.program"
    },
    "specializedTag": {
      "type": "string"
    },
    "isPopular": {
      "type": "boolean"
    },
    "order": {
      "type": "integer"
    },
    "hasDetailPage": {
      "type": "boolean",
      "default": false
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "programBadge": {
      "type": "string"
    },
    "featureTags": {
      "type": "string"
    },
    "curriculum_semesters": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::curriculum-semester.curriculum-semester",
      "mappedBy": "specialized_courses"
    }
  }
}
