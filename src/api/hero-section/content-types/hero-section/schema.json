{
  "kind": "collectionType",
  "collectionName": "hero_sections",
  "info": {
    "singularName": "hero-section",
    "pluralName": "hero-sections",
    "displayName": "Hero section",
    "description": "One entry per page: pageSlug matches your frontend route key; heroVariant selects which hero component renders."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "highlightText": {
      "type": "text"
    },
    "mainHeading": {
      "type": "text"
    },
    "Discription": {
      "type": "text"
    },
    "program": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::program.program"
    },
    "pointList": {
      "type": "text"
    },
    "pageType": {
      "type": "enumeration",
      "enum": [
        "MainProgram",
        "Elective"
      ]
    },
    "specialized_course": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::specializedcourse.specializedcourse"
    }
  }
}
